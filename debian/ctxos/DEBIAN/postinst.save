#!/bin/sh
set -e

echo "CtxOS Post-Installation Configuration"
echo "======================================="

if [ -f /etc/debian_version ]; then
    echo "Setting up CtxOS on Debian..."
    
    if [ ! -d /etc/ctxos ]; then
        mkdir -p /etc/ctxos
    fi
    
    if [ -f /etc/ctxos/dnsmasq.conf ]; then
        echo "DNS configuration found."
    fi
    
    systemctl daemon-reload 2>/dev/null || true
fi

echo "Post-installation complete."
