#!/bin/sh
set -e

case "$1" in
    remove)
        echo "Removing CtxOS..."
        ;;
    purge)
        echo "Purging CtxOS..."
        rm -rf /etc/ctxos 2>/dev/null || true
        rm -f /var/log/ctx-update.log 2>/dev/null || true
        ;;
    upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        ;;
    *)
        exit 1
        ;;
esac

exit 0
